@model LoginDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Admin Login</title>

    <link href="css/styles.css" rel="stylesheet" />
    <script src="https://use.fontawesome.com/releases/v6.1.0/js/all.js"></script>

    <style>
        body {
            margin: 0;
            height: 100vh;
        }

        .login-container {
            height: 100vh;
        }

        /* 🔥 Left Side */
        .left-side {
            background: url('/images/login-bg.jpg') center/cover no-repeat;
            position: relative;
            color: white;
        }

        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.25);
        }

        .left-content {
            position: relative;
            z-index: 2;
        }

        /* 🔥 Right Side */
        .right-side {
            display: flex;
            justify-content: center;
            align-items: center;
            background: #f8f9fa;
        }

        .login-card {
            width: 100%;
            max-width: 400px;
            padding: 30px;
            border-radius: 15px;
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            animation: fadeIn 0.5s ease-in-out;
        }

        .form-control {
            border-radius: 8px;
        }

        .btn-login {
            border-radius: 8px;
            padding: 10px;
            font-weight: bold;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 📱 Mobile */
        @@media (max-width: 768px) {
            .left-side {
                display: none;
            }
        }
    </style>
</head>

<body>

    <div class="container-fluid login-container">
        <div class="row h-100">

            <!-- 🔥 Left Side -->
            <div class="col-md-6 d-none d-md-block left-side">
                <div class="overlay"></div>

                <div class="d-flex flex-column justify-content-start align-items-center h-100 text-center left-content pt-5 mt-5">
                    <h1 class="fw-bold">Welcome Back </h1>
                    <p class="mt-3 px-5">
                        Manage your eCommerce dashboard, products, and orders.
                    </p>
                </div>
            </div>

            <!-- 🔥 Right Side -->
            <div class="col-md-6 right-side">

                <div class="login-card">

                    <div class="text-center mb-4">
                        <i class="fas fa-user-shield fa-2x text-primary"></i>
                        <h4 class="mt-2">Admin Login</h4>
                    </div>

                    <form method="post" asp-action="Login">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label>Email</label>
                            <input asp-for="@Model.Email" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label>Password</label>
                            <input asp-for="@Model.Password" class="form-control" type="password" />
                        </div>

                        <div class="d-flex justify-content-between mb-3">
                            <div>
                                <input type="checkbox" /> Remember me
                            </div>
                            <a href="#">Forgot?</a>
                        </div>

                        <button class="btn btn-primary btn-login w-100">
                            Login
                        </button>

                    </form>

                </div>

            </div>

        </div>
    </div>

</body>
</html>