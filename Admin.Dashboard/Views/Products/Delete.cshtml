@model ProductViewModel
@{
    ViewData["Title"] = "Delete";
}
<h1>Delete @Model.Name</h1>

<form method="post" asp-action="Delete" asp-route-id="@Model.Id">
    
    <h1 class="mt-3">Are you sure you want to delete this product? @Model.Name</h1>
    <input asp-for="Id" hidden />
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" readonly />
    </div>
    <div class="form-group">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" readonly />
    </div>
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" readonly />
    </div>
    <br />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Back to Index</a>
</form>